# Local .terraform directory (contains provider binaries and modules)
.terraform/

# .tfstate files (contain sensitive data and current infrastructure state)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files by default (often contain secrets)
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override files for specific environments if needed
# !example_override.tf

# CLI configuration files
.terraformrc
terraform.rc